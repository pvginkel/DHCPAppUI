library('JenkinsPipelineUtils') _

properties([
    parameters([
        string(name: 'BACKEND_BUILD', defaultValue: ''),
        string(name: 'FRONTEND_BUILD', defaultValue: ''),
        string(name: 'TRIGGERED_BY')
    ])
])

podTemplate(inheritFrom: 'jenkins-agent kaniko', containers: [
    containerTemplates.k8s('k8s')
]) {
    node(POD_LABEL) {
        def backendMeta
        def frontendMeta
        def jobName = "dhcpapp-validation-${BUILD_NUMBER}"
        def k8sNamespace = sh(script: 'cat /var/run/secrets/kubernetes.io/serviceaccount/namespace', returnStdout: true).trim()

        stage('Clone repo') {
            git branch: 'main',
                credentialsId: '5f6fbd66-b41c-405f-b107-85ba6fd97f10',
                url: 'https://github.com/pvginkel/DHCPAppUI.git'
        }

        stage('Resolve image pair') {
            copyArtifacts(
                projectName: 'DHCPApp',
                selector: params.BACKEND_BUILD ? specific(params.BACKEND_BUILD) : lastSuccessful(),
                filter: 'backend-build.json',
                target: 'backend-meta',
                flatten: true
            )

            copyArtifacts(
                projectName: 'DHCPAppUI',
                selector: params.FRONTEND_BUILD ? specific(params.FRONTEND_BUILD) : lastSuccessful(),
                filter: 'frontend-build.json',
                target: 'frontend-meta',
                flatten: true
            )

            backendMeta = readJSON file: 'backend-meta/backend-build.json'
            frontendMeta = readJSON file: 'frontend-meta/frontend-build.json'

            echo "Testing backend=${backendMeta.tag} (${backendMeta.gitRev})"
            echo "Testing frontend=${frontendMeta.tag} (${frontendMeta.gitRev})"
        }

        stage('Clone source repos') {
            dir('backend-src') {
                git branch: 'main',
                    credentialsId: '5f6fbd66-b41c-405f-b107-85ba6fd97f10',
                    url: 'https://github.com/pvginkel/DHCPApp.git'
                sh "git checkout ${backendMeta.gitRev}"
            }
            dir('frontend-src') {
                git branch: 'main',
                    credentialsId: '5f6fbd66-b41c-405f-b107-85ba6fd97f10',
                    url: 'https://github.com/pvginkel/DHCPAppUI.git'
                sh "git checkout ${frontendMeta.gitRev}"
            }
        }

        stage('Build validation image') {
            container('kaniko') {
                helmCharts.kaniko(
                    "Dockerfile.validation",
                    ".",
                    [
                        "registry:5000/dhcpapp-validation:${currentBuild.number}"
                    ]
                )
            }
        }

        stage('Run validation') {
            container('k8s') {
                def testImage = "registry:5000/dhcpapp-validation:${currentBuild.number}"

                withEnv([
                    "K8S_JOB_NAME=${jobName}",
                    "K8S_NAMESPACE=${k8sNamespace}",
                    "TEST_IMAGE=${testImage}"
                ]) {
                    sh '''
                        set -euo pipefail

                        cat > e2e-job.yaml <<EOF
apiVersion: batch/v1
kind: Job
metadata:
  name: $K8S_JOB_NAME
  namespace: $K8S_NAMESPACE
  labels:
    app.kubernetes.io/name: dhcpapp-validation
    app.kubernetes.io/managed-by: jenkins
    jenkins/build-number: "$BUILD_NUMBER"
spec:
  backoffLimit: 0
  activeDeadlineSeconds: 3600
  ttlSecondsAfterFinished: 86400
  template:
    metadata:
      labels:
        app.kubernetes.io/name: dhcpapp-validation
        job-name: $K8S_JOB_NAME
    spec:
      restartPolicy: Never
      containers:
        - name: validation
          image: $TEST_IMAGE
          imagePullPolicy: Always
EOF

                        kubectl apply -f e2e-job.yaml
                    '''

                    sh '''
                        set -euo pipefail

                        while true; do
                            complete="$(kubectl get job "$K8S_JOB_NAME" -n "$K8S_NAMESPACE" \
                                -o jsonpath='{.status.conditions[?(@.type=="Complete")].status}' 2>/dev/null || true)"
                            failed="$(kubectl get job "$K8S_JOB_NAME" -n "$K8S_NAMESPACE" \
                                -o jsonpath='{.status.conditions[?(@.type=="Failed")].status}' 2>/dev/null || true)"

                            if [ "$complete" = "True" ] || [ "$failed" = "True" ]; then
                                break
                            fi

                            sleep 10
                        done
                    '''

                    def podName = sh(
                        script: "kubectl get pods -n '${k8sNamespace}' -l job-name='${jobName}' -o jsonpath='{.items[0].metadata.name}'",
                        returnStdout: true
                    ).trim()

                    sh "kubectl logs -n '${k8sNamespace}' '${podName}' -c validation > validation-raw.log 2>&1 || true"

                    sh '''
                        set -euo pipefail

                        mkdir -p test-results

                        awk '
                            /^===JUNIT:.*===$/ {
                                fname = $0
                                sub(/^===JUNIT:/, "", fname)
                                sub(/===$/, "", fname)
                                content = ""
                                capture = 1
                                next
                            }
                            /^===JUNIT_END===$/ {
                                print content | "base64 -d > test-results/" fname
                                close("base64 -d > test-results/" fname)
                                capture = 0
                                next
                            }
                            capture { content = content (content ? "\\n" : "") $0 }
                            !capture { print }
                        ' validation-raw.log > validation.log
                    '''
                    archiveArtifacts artifacts: 'validation.log', allowEmptyArchive: true
                    junit testResults: 'test-results/*.xml', allowEmptyResults: true

                    def exitCode = sh(
                        script: "kubectl get pod '${podName}' -n '${k8sNamespace}' -o jsonpath='{.status.containerStatuses[?(@.name==\"validation\")].state.terminated.exitCode}'",
                        returnStdout: true
                    ).trim()

                    currentBuild.description = "job=${jobName}, pod=${podName}, exit=${exitCode ?: 'n/a'}"

                    if (!exitCode) {
                        def failReason = sh(
                            script: "kubectl get job '${jobName}' -n '${k8sNamespace}' -o jsonpath='{.status.conditions[?(@.type==\"Failed\")].reason}'",
                            returnStdout: true
                        ).trim()
                        error("No exit code found for pod ${podName}${failReason ? " (reason: ${failReason})" : ""}")
                    }

                    if (exitCode != '0') {
                        error("Validation failed with exit code ${exitCode}")
                    }
                }
            }
        }

        stage('Promote build') {
            container('k8s') {
                sh "crane tag --insecure registry:5000/dhcpapp${backendMeta.tag} latest"
                sh "crane tag --insecure registry:5000/dhcpapp-ui${frontendMeta.tag} latest"
            }
        }

        stage('Deploy Helm charts') {
            build job: 'HelmCharts', wait: false
        }
    }
}
